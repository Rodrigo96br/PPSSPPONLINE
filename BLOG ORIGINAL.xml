*{
    margin:0;
    padding:20;
    box-sizing:border-box;
}
body{
    opacity:1;
    font-family:Arial, Helvetica, sans-serif;
    overflow-x:auto;
    background-image: url('https://i.pinimg.com/1200x/51/fc/a0/51fca09b9d25e25e1f08c7bcf6c05421.jpg');
    background-repeat: no-repeat;
    background-size: cover; /* Faz a imagem cobrir toda a tela */
    background-attachment: fixed; /* Opcional: fixa a imagem ao rolar */
    background-position: center;
    color:#fff;
}      
/* TOPO */
.titulo{
    text-align:center;
    font-size:30px;
    font-weight:bold;
    color:#fff;
    text-shadow:0 0 15px gold;
}
.texto-final{
    text-align:center;
    font-size:30px;
    font-weight:bold;
    color:#fff;
    text-shadow:0 0 10px gold;
    position:relative;
    top:175px;
}
  .trofeu{
    position: absolute;
    top:95px;
    left:175px;
    transform:translateX(-50%);
    font-size:10px;
    animation:flutuar 2s infinite ease-in-out;
}
  .trofeu img{
    width:60px;
    height:90px;
    object-fit:contain;
}

@keyframes flutuar{
    0%{transform:translateX(-50%) translateY(0px);}
    50%{transform:translateX(-50%) translateY(-10px);}
    100%{transform:translateX(-50%) translateY(0px);}
}
/* ////////// CAIXA 1 ////////// */
.caixa-1{
    width:40px;
    height:120px;
    opacity:1;
    border:2px solid #fff;
    border-radius:10px;
    text-align:center;
    box-shadow:0 0 12px #ffffff55;
}
.time-1 img{
    width:30px;
    height:48px;
    object-fit:contain;
}
.vs-1{
    font-size:18px;
    font-weight:bold;
}
/* ////////// CAIXA 2 ////////// */
