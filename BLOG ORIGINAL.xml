/* ////////// CAIXA FINAL ////////// */
   .caixa-final{
    width:60px;
    height:160px;
    opacity:1;
    border:4px solid gold;
    border-radius:10px;
    text-align:center;
    box-shadow:0 0 12px #ffffff55;
